# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 社群連結 ─────────────────────────────────
NEXT_PUBLIC_LINE_ID=@your-line-id
NEXT_PUBLIC_FB_URL=https://www.facebook.com/YOUR_FB_PAGE
NEXT_PUBLIC_IG_URL=https://www.instagram.com/YOUR_IG_HANDLE

# ── 開發者驗證 ───────────────────────────────
# DEV_AUTH_SECRET: HMAC 簽名密鑰（必填，否則開發者模式無法登入）
DEV_AUTH_SECRET=your-random-secret-at-least-32-chars
# NEXT_PUBLIC_DEV_PASSWORD: 前端輸入的開發者密碼
NEXT_PUBLIC_DEV_PASSWORD=your-dev-password
# DEV_LINE_USER_ID: 允許登入的 LINE 使用者 ID
DEV_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LINE Login（開發者模式 OAuth）────────────
LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id
LINE_LOGIN_CHANNEL_SECRET=your-line-login-channel-secret
